# Copy to .env and adjust for your environment. Never commit the real .env.

PORT=3001
NODE_ENV=production

# Path to the documentation JSON file (defaults to ./ue-repositories-docs.json)
DOCS_PATH=./ue-repositories-docs.json

# Comma-separated list of origins allowed to call this API via CORS.
# Leave empty to disable cross-origin requests entirely (same-origin only).
ALLOWED_ORIGINS=https://docs.example.com,https://app.example.com

# Set to 1 (or a specific value like "loopback") if running behind a
# reverse proxy / load balancer (nginx, Heroku, Render, etc.)
TRUST_PROXY=1

# Max requests per IP per 15-minute window on /api/* routes
RATE_LIMIT_MAX=300
